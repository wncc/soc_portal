# Backend Environment Configuration Example
# Replace these values with your actual configuration

# Django Secret Key - Use a strong random key in production
DJANGO_SECRET_KEY="django-insecure-d+#y%l^0ihv^!n85jt7ckxco6(b=0(a3+e+fml#3t0ef2gbs3k"

# Debug mode (True for development, False for production)
DJANGO_DEBUG=True

# Email configuration for sending notifications
EMAIL_HOST_USER=your_email@example.com
EMAIL_PASSWORD=your_app_password

# Database URL
# Keep SQLite for local development:
DATABASE_URL=sqlite:///db.sqlite3
MANAGER_SECRET_TOKEN=your-manager-secret-token
# Example PostgreSQL URL (uncomment and edit if needed):
# DATABASE_URL=postgres://db_user:db_password@db_host:5432/db_name